####### Compile

main.o: main.cpp utils.h \
		ui_perfect_pitch.h \
		ppstatusbar.h \
		ppwidget.h \
		kde_ui.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

kde_ui.o: kde_ui.cpp ui_perfect_pitch.h \
		ppstatusbar.h \
		ppwidget.h \
		utils.h \
		kde_ui.h \
		worker.h \
		unix_sound.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o kde_ui.o kde_ui.cpp

ppwidget.o: ppwidget.cpp utils.h \
		ui_perfect_pitch.h \
		ppstatusbar.h \
		ppwidget.h \
		kde_ui.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ppwidget.o ppwidget.cpp

ppstatusbar.o: ppstatusbar.cpp ppstatusbar.h \
		utils.h \
		unix_sound.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ppstatusbar.o ppstatusbar.cpp

worker.o: worker.cpp utils.h \
		worker.h \
		unix_sound.h \
		perfect_pitch.h \
		ui_perfect_pitch.h \
		ppstatusbar.h \
		ppwidget.h \
		kde_ui.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o worker.o worker.cpp

utils.o: utils.c utils.h
	$(CC) -c $(CFLAGS) $(INCPATH) -o utils.o utils.c

perfect_pitch.o: perfect_pitch.c utils.h \
		unix_sound.h \
		perfect_pitch.h
	$(CC) -c $(CFLAGS) $(INCPATH) -o perfect_pitch.o perfect_pitch.c

unix_sound.o: unix_sound.c utils.h \
		unix_sound.h \
		perfect_pitch.h
	$(CC) -c $(CFLAGS) $(INCPATH) -o unix_sound.o unix_sound.c

moc_kde_ui.o: moc_kde_ui.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_kde_ui.o moc_kde_ui.cpp

moc_ppwidget.o: moc_ppwidget.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_ppwidget.o moc_ppwidget.cpp

moc_ppstatusbar.o: moc_ppstatusbar.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_ppstatusbar.o moc_ppstatusbar.cpp

