		/usr/lib/qt6/libexec/moc
	/usr/lib/qt6/libexec/moc $(DEFINES) --include /home/pi/development/perfect_pitch.test/moc_predefs.h -I/usr/lib/i386-linux-gnu/qt6/mkspecs/linux-g++ -I/home/pi/development/perfect_pitch.test -I/usr/include/i386-linux-gnu/qt6 -I/usr/include/i386-linux-gnu/qt6/QtWidgets -I/usr/include/i386-linux-gnu/qt6/QtGui -I/usr/include/i386-linux-gnu/qt6/QtCore -I/usr/include/c++/14 -I/usr/include/i386-linux-gnu/c++/14 -I/usr/include/c++/14/backward -I/usr/lib/gcc/i686-linux-gnu/14/include -I/usr/local/include -I/usr/include/i386-linux-gnu -I/usr/include kde_ui.h -o moc_kde_ui.cpp

